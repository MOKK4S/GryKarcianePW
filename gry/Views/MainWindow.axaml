<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:gry.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="gry.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="GryKarcianePW"
        Width="600" Height="500">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <StackPanel IsVisible="{Binding IsStartMenuVisible}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
            <TextBlock Text="MENU GŁÓWNE" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
            <Button Content="Dodaj gracza" Command="{Binding GoToAddPlayerCommand}" Width="200" HorizontalContentAlignment="Center"/>
            <Button Content="Graj (Logowanie)" Command="{Binding GoToLoginCommand}" Width="200" HorizontalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel IsVisible="{Binding IsAddPlayerVisible}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
            <TextBlock Text="DODAJ GRACZA" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Wpisz ID (3-10 cyfr):" />
            <TextBox Text="{Binding InputPlayerId}" Width="200"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center"/>
            <Button Content="Dodaj" Command="{Binding RegisterPlayerCommand}" Width="200" HorizontalContentAlignment="Center" Background="LightGreen"/>
            <Button Content="Wróć" Command="{Binding GoToStartMenuCommand}" Width="200" HorizontalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel IsVisible="{Binding IsLoginVisible}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
            <TextBlock Text="LOGOWANIE" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Wpisz swoje ID:" />
            <TextBox Text="{Binding InputPlayerId}" Width="200"/>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center"/>
            <Button Content="Zaloguj" Command="{Binding LoginPlayerCommand}" Width="200" HorizontalContentAlignment="Center" Background="LightBlue"/>
            <Button Content="Wróć" Command="{Binding GoToStartMenuCommand}" Width="200" HorizontalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel IsVisible="{Binding IsGamesMenuVisible}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
            <TextBlock Text="WYBIERZ GRĘ" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
            <Button Content="Higher Lower" Command="{Binding GoToHlMenuCommand}" Width="250" HorizontalContentAlignment="Center"/>
            <Button Content="Blackjack" Command="{Binding GoToBlackjackMenuCommand}" Width="250" HorizontalContentAlignment="Center"/>
            <Button Content="Gra 3" Width="250" HorizontalContentAlignment="Center" IsEnabled="False"/>
            <Button Content="Historia gier" Command="{Binding GoToHistoryCommand}" Width="250" HorizontalContentAlignment="Center" Background="Gray"/>
            <Button Content="Wyloguj" Command="{Binding GoToStartMenuCommand}" Width="250" HorizontalContentAlignment="Center" Background="IndianRed"/>
        </StackPanel>

        <StackPanel IsVisible="{Binding IsHlMenuVisible}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
            <TextBlock Text="HIGHER LOWER" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
            <Button Content="Graj" Command="{Binding StartGameCommand}" Width="200" HorizontalContentAlignment="Center" Background="LightGreen"/>
            <Button Content="Info" Command="{Binding GoToHlInfoCommand}" Width="200" HorizontalContentAlignment="Center" Background="LightBlue"/>
            <Button Content="Wróć do Lobby" Command="{Binding GoToGamesMenuCommand}" Width="200" HorizontalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel IsVisible="{Binding IsHlInfoVisible}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15" MaxWidth="400">
            <TextBlock Text="ZASADY GRY" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock TextWrapping="Wrap" Text="Mamy całą talię kart (52 sztuki). Zostaje wylosowana jedna karta na środek. Musisz ocenić, czy następna wylosowana karta z talii będzie większa, czy mniejsza. Wartości od najsłabszej: 2-10, Jopek, Dama, Król, As. Karta wyrzucona odpada z gry. Gra kończy się, gdy skończą się karty."/>
            <Button Content="Wróć" Command="{Binding GoToHlMenuCommand}" Width="200" HorizontalContentAlignment="Center" Margin="0,20,0,0"/>
        </StackPanel>

        <StackPanel IsVisible="{Binding IsBlackjackMenuVisible}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
            <TextBlock Text="BLACKJACK" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
            <Button Content="Graj" Command="{Binding StartBlackjackCommand}" Width="200" HorizontalContentAlignment="Center" Background="LightGreen"/>
            <Button Content="Wróć do Lobby" Command="{Binding GoToGamesMenuCommand}" Width="200" HorizontalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel IsVisible="{Binding IsHlGameVisible}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
            <TextBlock Text="HIGHER LOWER" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding GameMessage}" HorizontalAlignment="Center" FontSize="16" Foreground="Orange"/>
            <Border Background="White" BorderBrush="Black" BorderThickness="2" CornerRadius="10" Width="100" Height="140">
                <TextBlock Text="{Binding CurrentCardName}" Foreground="Black" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
            </Border>
            <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                <Button Content="Wyższa ▲" Command="{Binding GuessHigherCommand}" Width="100" HorizontalContentAlignment="Center" Background="ForestGreen" Foreground="White" IsEnabled="{Binding CardsLeft}"/>
                <Button Content="Niższa ▼" Command="{Binding GuessLowerCommand}" Width="100" HorizontalContentAlignment="Center" Background="Firebrick" Foreground="White" IsEnabled="{Binding CardsLeft}"/>
            </StackPanel>
            
            <StackPanel Spacing="10">
                <Button Content="Podejrzyj kartę (50%)" Command="{Binding CheatCommand}" Width="220" HorizontalContentAlignment="Center" Background="Orange" Foreground="White" IsEnabled="{Binding CardsLeft}"/>
                <TextBlock Text="{Binding CheatMessage}" Foreground="Orange" HorizontalAlignment="Center" FontWeight="Bold" TextWrapping="Wrap" MaxWidth="300" TextAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="{Binding StringFormat='Pozostało kart: {0}', Path=CardsLeft}" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding StringFormat='Wynik: {0}/{1}', Path=CurrentScore}" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold"/>
            <Button Content="Wyjdź do Menu" Command="{Binding GoToGamesMenuCommand}" Width="200" HorizontalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel IsVisible="{Binding IsBlackjackGameVisible}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <TextBlock Text="BLACKJACK" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>

            <TextBlock Text="Krupier:" FontWeight="Bold" HorizontalAlignment="Center"/>
            <ItemsControl ItemsSource="{Binding BjDealerCards}" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:Card">
                        <Border Background="White" BorderBrush="Black" BorderThickness="2" CornerRadius="10" Width="80" Height="110">
                            <TextBlock Text="{Binding Name}" Foreground="Black" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Twoje karty:" FontWeight="Bold" HorizontalAlignment="Center"/>
            <ItemsControl ItemsSource="{Binding BjPlayerCards}" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:Card">
                        <Border Background="White" BorderBrush="Black" BorderThickness="2" CornerRadius="10" Width="80" Height="110">
                            <TextBlock Text="{Binding Name}" Foreground="Black" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{Binding StringFormat='Wartość: {0}', Path=PlayerHandValue}" HorizontalAlignment="Center" FontSize="12" Foreground="DimGray"/>

            <TextBlock Text="{Binding BjMessage}" HorizontalAlignment="Center" FontSize="14" Foreground="Orange" TextWrapping="Wrap" TextAlignment="Center"/>

            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" IsVisible="{Binding BjIsNotRevealing}">
                <Button Content="Hit (Dobierz)" Command="{Binding BjHitCommand}" Width="120" HorizontalContentAlignment="Center" Background="ForestGreen" Foreground="White" IsEnabled="{Binding BjCanAct}"/>
                <Button Content="Stand (Zostań)" Command="{Binding BjStandCommand}" Width="120" HorizontalContentAlignment="Center" Background="Firebrick" Foreground="White" IsEnabled="{Binding BjCanAct}"/>
                <Button Content="Reveal 🎲" Command="{Binding BjRevealCommand}" Width="100" HorizontalContentAlignment="Center" Background="DarkViolet" Foreground="White" IsEnabled="{Binding BjCanAct}"/>
            </StackPanel>

            <StackPanel IsVisible="{Binding BjIsRevealing}" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="Odsłonięta karta:" FontWeight="Bold" HorizontalAlignment="Center"/>
                <Border Background="White" BorderBrush="Gold" BorderThickness="3" CornerRadius="10" Width="80" Height="110" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding BjRevealedCardName}" Foreground="Black" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                </Border>
                <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                    <Button Content="Weź ✓" Command="{Binding BjTakeRevealedCommand}" Width="110" HorizontalContentAlignment="Center" Background="ForestGreen" Foreground="White"/>
                    <Button Content="Pomiń ✗" Command="{Binding BjSkipRevealedCommand}" Width="110" HorizontalContentAlignment="Center" Background="DarkOrange" Foreground="White"/>
                </StackPanel>
            </StackPanel>

            <Button Content="Zagraj ponownie" Command="{Binding StartBlackjackCommand}" Width="200" HorizontalContentAlignment="Center" Background="LightBlue" IsVisible="{Binding BjGameOver}"/>
            <Button Content="Wyjdź do Menu" Command="{Binding GoToGamesMenuCommand}" Width="200" HorizontalContentAlignment="Center"/>
        </StackPanel>

        <ScrollViewer IsVisible="{Binding IsHistoryVisible}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Spacing="10" Margin="20">
                <TextBlock Text="{Binding StringFormat='Gracz {0}', Path=CurrentPlayerId}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                
                <TextBlock Text="HIGHER LOWER" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <ItemsControl ItemsSource="{Binding CurrentHlResults}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="BLACKJACK" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <ItemsControl ItemsSource="{Binding CurrentGame2Results}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="GRA 3" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <ItemsControl ItemsSource="{Binding CurrentGame3Results}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Wróć do Lobby" Command="{Binding GoToGamesMenuCommand}" Width="200" HorizontalContentAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>